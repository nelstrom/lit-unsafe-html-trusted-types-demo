title: "2. DOMPurify"
---

<article>
  <span class="badge badge-warning">NO ENFORCEMENT</span>
  <h2>2. DOMPurify</h2>

  <div class="csp-indicator csp-off">● Trusted Types: OFF</div>

  <div class="outcome-grid">
    <span class="outcome-label">Expected:</span>
    <span>No XSS — DOMPurify strips the <code>onerror</code> attribute before rendering.</span>
    <span class="outcome-label">What actually happens:</span>
    <span class="outcome-match">✓ No alert — but nothing enforces that sanitization was called.</span>
  </div>

  <div class="code-block">
    <div class="code-block-label">demo-2.js</div>
{% highlight "javascript" %}
import { html, render } from 'lit-html';
import { unsafeHTML } from 'lit-html/directives/unsafe-html.js';
import DOMPurify from 'dompurify';

document.getElementById('run-btn').addEventListener('click', () => {
  const userInput = document.getElementById('user-input').value;
  const sanitized = DOMPurify.sanitize(userInput);
  const result = document.getElementById('result');
  result.textContent = '';
  const litTarget = document.createElement('div');
  result.appendChild(litTarget);
  render(html`<div>${unsafeHTML(sanitized)}</div>`, litTarget);
});
{% endhighlight %}
  </div>

  <div class="demo-area">
    <label for="user-input">HTML input:</label>
    <textarea id="user-input" rows="3"><img src=x onerror="alert('XSS!')"> Hello!</textarea>
    <button class="run-btn" id="run-btn">Run Demo</button>
    <div id="result"></div>
  </div>

