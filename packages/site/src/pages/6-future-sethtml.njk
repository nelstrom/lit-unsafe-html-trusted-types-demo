<article>
  <span class="badge badge-info">FUTURE</span>
  <h2>6. Future Direction: setHTML()</h2>

  <div class="csp-indicator csp-on">
    ● Trusted Types: ON — <code>require-trusted-types-for 'script'; trusted-types dompurify lit-html</code>
  </div>

  <p>
    The <a href="https://developer.mozilla.org/en-US/docs/Web/API/Element/setHTML" target="_blank">Sanitizer API</a>
    (<code>element.setHTML()</code>) is a <em>safe sink</em> — not a Trusted Types sink.
    The browser sanitizes the HTML itself before insertion, so no <code>TrustedHTML</code>
    is required and no Trusted Types policy is needed.
  </p>

  <p>
    A future <code>safeHtml(string, sanitizerConfig)</code> directive could use this API
    directly, making sanitization a browser-enforced guarantee rather than a developer
    convention.
  </p>

  <div class="code-block">
    <div class="code-block-label">Hypothetical safeHtml directive sketch</div>
{% highlight "javascript" %}
// Hypothetical — not yet implemented in this demo
function safeHtmlDirective(value, sanitizerConfig = {}) {
  return {
    render() { return nothing; },
    update(part) {
      if (!('setHTML' in Element.prototype)) {
        // Graceful degradation: fall back to DOMPurify + unsafeHtmlTT
        const clean = DOMPurify.sanitize(value, { RETURN_TRUSTED_TYPE: true });
        unsafeHtmlTT(clean).update(part);
        return noChange;
      }
      const div = document.createElement('div');
      div.setHTML(value, { sanitizer: sanitizerConfig });
      // Insert nodes into part...
      return noChange;
    }
  };
}
{% endhighlight %}
  </div>

  <div class="code-block">
    <div class="code-block-label">demo-6.js — what you're running</div>
{% highlight "javascript" %}
const userInput = `<img src=x onerror="alert('XSS!')"><p>Hello from setHTML()!</p>`;
const container = document.querySelector('#result');

if ('setHTML' in Element.prototype) {
  // setHTML is a safe sink — browser sanitizes before insertion
  container.setHTML(userInput);
} else {
  container.textContent =
    'setHTML() is not available in this browser. ' +
    'Try Firefox 148+ or Chrome with the Sanitizer API flag.';
}
{% endhighlight %}
  </div>

