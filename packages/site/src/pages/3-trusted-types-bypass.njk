<article>
  <span class="badge badge-danger">BYPASS</span>
  <h2>3. TT Bypass</h2>

  <div class="csp-indicator csp-on">● Trusted Types: ON</div>

  <div class="outcome-grid">
    <span class="outcome-label">Expected:</span>
    <span>Trusted Types blocks the raw string — no alert.</span>
    <span class="outcome-label">What actually happens:</span>
    <span class="outcome-mismatch">✗ Alert fires anyway — Lit's internal <code>'lit-html'</code> policy bypasses TT.</span>
  </div>

  <div class="code-block">
    <div class="code-block-label">demo-3.js</div>
{% highlight "javascript" %}
import { html, render } from 'lit-html';
import { unsafeHTML } from 'lit-html/directives/unsafe-html.js';

document.getElementById('run-btn').addEventListener('click', () => {
  const userInput = document.getElementById('user-input').value;
  const target = document.getElementById('result');
  target.textContent = '';
  render(html`<div>${unsafeHTML(userInput)}</div>`, target);
});
{% endhighlight %}
  </div>

  <div class="demo-area">
    <label for="user-input">HTML input:</label>
    <textarea id="user-input" rows="3"><img src=x onerror="alert('TT bypass!')"> Hello!</textarea>
    <button class="run-btn" id="run-btn">Run Demo</button>
    <div id="result"></div>
  </div>

