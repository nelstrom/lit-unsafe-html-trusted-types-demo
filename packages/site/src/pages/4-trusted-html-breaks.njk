<article>
  <span class="badge badge-warning">THROWS</span>
  <h2>4. TH Breaks</h2>

  <div class="csp-indicator csp-on">● Trusted Types: ON</div>

  <div class="outcome-grid">
    <span class="outcome-label">Expected:</span>
    <span>Renders safely — DOMPurify returns <code>TrustedHTML</code>, which <code>unsafeHTML()</code> should accept.</span>
    <span class="outcome-label">What actually happens:</span>
    <span class="outcome-mismatch">✗ Throws — <code>unsafeHTML()</code> rejects non-string values. Check DevTools console.</span>
  </div>

  <div class="code-block">
    <div class="code-block-label">demo-4.js</div>
{% highlight "javascript" %}
import { html, render } from 'lit-html';
import { unsafeHTML } from 'lit-html/directives/unsafe-html.js';
import DOMPurify from 'dompurify';

document.getElementById('run-btn').addEventListener('click', () => {
  const userInput = document.getElementById('user-input').value;
  const trustedHtml = DOMPurify.sanitize(userInput, { RETURN_TRUSTED_TYPE: true });
  const result = document.getElementById('result');
  result.textContent = '';
  const litTarget = document.createElement('div');
  result.appendChild(litTarget);
  render(html`<div>${unsafeHTML(trustedHtml)}</div>`, litTarget);
});
{% endhighlight %}
  </div>

  <div class="demo-area">
    <label for="user-input">HTML input:</label>
    <textarea id="user-input" rows="3"><img src=x onerror="alert('XSS!')"> Hello!</textarea>
    <button class="run-btn" id="run-btn">Run Demo</button>
    <div id="result"></div>
  </div>

